# Neon Postgres connection string (get this from your Neon project dashboard).
# Use the pooled connection string — it works over HTTP and is what the
# @neondatabase/serverless driver expects. It looks like:
# postgresql://user:password@ep-something-pooler.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# Optional: set this to protect the whole app behind a single shared password.
# Leave blank while developing locally if you don't want a login screen yet.
APP_PASSWORD=

# Vercel Blob token — Vercel dashboard → Storage → create a Blob store →
# connect it to this project (auto-injects this in production/preview).
# For local dev: `vercel link` then `vercel env pull .env.local`.
BLOB_READ_WRITE_TOKEN=
